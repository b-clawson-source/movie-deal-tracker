# Database URL (PostgreSQL for Railway, leave blank for SQLite locally)
# Railway will auto-populate this when you add a PostgreSQL database
DATABASE_URL=

# SerpAPI Key - Get from https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# From address - use resend.dev for testing, or verify your own domain
EMAIL_FROM=Movie Deal Tracker <deals@resend.dev>

# Web Application Settings
SECRET_KEY=your_secret_key_here_generate_a_random_string
BASE_URL=https://your-app-name.railway.app

# Worker Schedule (24-hour format)
SCHEDULE_RUN_AT=09:00

# Optional: Flask debug mode (set to true for local development)
FLASK_DEBUG=false
